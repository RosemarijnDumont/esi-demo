# auth_service/.env.example
# Example environment variables for the authentication service.
# In a production environment, these values should be securely managed
# and not hardcoded or publicly exposed.

SECRET_KEY='your_super_secret_key_change_this_in_production'
ACCESS_TOKEN_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=7
DATABASE_URL='sqlite:///./test.db' # Example, replace with your actual DB URL
